<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{Astro.props.title}</title>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.2/dist/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.2/dist/ScrollTrigger.min.js"></script>
    <script src="https://unpkg.com/@studio-freight/lenis@1.0.33/dist/lenis.min.js"></script>
    <style is:global>
        :root {
            --bg: hsl(222, 47%, 4%);
            --surface: hsl(222, 47%, 12% / 0.6);
            --primary: hsl(263, 90%, 65%);
            --secondary: hsl(180, 100%, 50%);
            --text-main: hsl(0, 0%, 98%);
            --text-muted: hsl(215, 20%, 65%);
            --glass-border: 1px solid hsla(0, 0%, 100%, 0.1);
            --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        }

        body {
            background-color: var(--bg);
            color: var(--text-main);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        .glass-card {
            background: var(--surface);
            backdrop-filter: blur(16px) saturate(180%);
            border: var(--glass-border);
            box-shadow: var(--glass-shadow);
            border-radius: 24px;
            transition: transform 0.3s cubic-bezier(0.2, 0, 0.2, 1), border-color 0.3s ease;
        }

        .glass-card:hover {
            border-color: var(--primary);
            transform: translateY(-5px);
        }

        .text-gradient {
            background: linear-gradient(135deg, var(--text-main) 0%, var(--text-muted) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
            padding: 12px 24px;
            border-radius: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 0 20px hsla(263, 90%, 65%, 0.4);
        }

        .btn-primary:hover {
            box-shadow: 0 0 30px hsla(263, 90%, 65%, 0.6);
            transform: scale(1.05);
        }
    </style>
</head>
<body>
    <slot />
    <script>
        const lenis = new Lenis();
        function raf(time) {
            lenis.raf(time);
            requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
    </script>
</body>
</html>